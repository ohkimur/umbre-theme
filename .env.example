# Publishing secrets for .github/workflows/publish-extension.yml
#
# Do not put real token values in this file. Add the real values in GitHub:
# Repository → Settings → Secrets and variables → Actions → New repository secret.

# Visual Studio Marketplace
# Create this in Azure DevOps:
# 1. Go to https://dev.azure.com/ and open User settings → Personal access tokens.
# 2. Create a token for "All accessible organizations".
# 3. Use Custom defined scopes → Marketplace → Manage.
# 4. Add the token to GitHub Actions as the repository secret VSCE_PAT.
VSCE_PAT=

# Open VSX / Cursor-compatible editors
# Create this in Open VSX:
# 1. Create an Eclipse account at https://accounts.eclipse.org/user/register.
# 2. Log in to https://open-vsx.org/ with GitHub.
# 3. Link the same Eclipse account and sign the Open VSX Publisher Agreement.
# 4. Go to https://open-vsx.org/user-settings/tokens and generate a token.
# 5. Create the publisher namespace once if needed:
#    bun x ovsx create-namespace ohkimur -p "$OVSX_PAT"
# 6. Add the token to GitHub Actions as the repository secret OVSX_PAT.
OVSX_PAT=
